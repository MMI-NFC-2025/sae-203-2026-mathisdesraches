---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Page introuvable - Jumelage">
  <Header />

  <main class="bg-bg pt-24 md:pt-28">
    
    <section class="px-4 pb-24 md:px-8 md:pb-32">
      <div class="mx-auto max-w-6xl">

        <p class="mb-4 text-xs font-bold uppercase tracking-festival text-black/50">
          Festival Jumelage
        </p>

        <div class="grid gap-12 md:grid-cols-[1.1fr_0.9fr] md:items-center">

          <div>

            <h1 class="text-6xl font-black uppercase tracking-festival text-[#273b6a] md:text-8xl">
              404
            </h1>

            <h2 class="mt-4 text-3xl font-black uppercase tracking-wide text-blackJ md:text-4xl">
              Page introuvable
            </h2>

            <p class="mt-6 max-w-xl text-base leading-8 text-black/70">
              La page que vous cherchez n’existe pas ou a été déplacée.
              Vous pouvez retourner à l’accueil ou explorer les différentes
              sections du festival.
            </p>

            <div class="mt-10 flex flex-wrap gap-3">

              <a
                href="/"
                class="bg-blueJ px-6 py-4 text-xs font-bold uppercase tracking-festival text-white md:text-sm"
              >
                Retour à l’accueil
              </a>

              <a
                href="/programme"
                class="border border-black/20 px-6 py-4 text-xs font-bold uppercase tracking-festival text-blackJ md:text-sm"
              >
                Voir le programme
              </a>

            </div>

          </div>

          

        </div>

      </div>
    </section>

    <section class="bg-darkJ px-4 py-12 text-white md:px-8 md:py-16">
      <div class="mx-auto max-w-6xl">

        <h2 class="text-3xl font-black uppercase tracking-festival md:text-4xl">
          Continuez votre visite
        </h2>

        <p class="mt-5 max-w-2xl text-sm leading-7 text-white/85 md:text-base">
          Explorez les artistes, les scènes et la programmation du festival
          pour découvrir tout ce que l’édition Jumelage vous réserve.
        </p>

        <div class="mt-8 grid gap-3 md:grid-cols-3">

          <a
            href="/artistes"
            class="bg-blueJ px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-white md:text-sm"
          >
            Voir les artistes
          </a>

          <a
            href="/scenes"
            class="bg-white px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-blackJ md:text-sm"
          >
            Découvrir les scènes
          </a>

          <a
            href="/programme"
            class="border border-white px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-white md:text-sm"
          >
            Voir le programme
          </a>

        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>