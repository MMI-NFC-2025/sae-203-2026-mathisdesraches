---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const tarifs = [
  {
    titre: "Pass 1 jour",
    prix: "25€",
    texte: "Accès à l’ensemble du festival pour une journée, avec toutes les scènes ouvertes au public.",
  },
  {
    titre: "Pass 2 jours",
    prix: "45€",
    texte: "Une formule idéale pour profiter du festival sur deux journées et découvrir plusieurs univers.",
  },
  {
    titre: "Pass 3 jours",
    prix: "60€",
    texte: "L’expérience complète pour vivre toute l’édition 2026 du Festival Jumelage.",
  },
];

const services = [
  {
    titre: "Hébergements",
    image: "/images/hebergement.png",
    texte: "Retrouvez des solutions à proximité du festival : hôtels, campings et locations temporaires pour prolonger l’expérience en toute sérénité.",
  },
  {
    titre: "Transport",
    image: "/images/transport.png",
    texte: "Le site est accessible en train, en voiture et en covoiturage. Des parkings et des accès dédiés sont prévus pour fluidifier l’arrivée des festivaliers.",
  },
  {
    titre: "Restauration",
    image: "/images/restauration.png",
    texte: "Des espaces de restauration sont répartis sur le site pour proposer boissons, encas et repas tout au long de la journée.",
  },
];

const faq = [
  {
    question: "Le festival est-il accessible à tous ?",
    reponse:
      "Oui, le festival met en place des dispositifs pensés pour accueillir le plus grand nombre dans de bonnes conditions.",
  },
  {
    question: "Peut-on entrer et sortir librement du site ?",
    reponse:
      "Selon le pass choisi, les conditions d’accès sont précisées par l’organisation afin de garantir la fluidité et la sécurité du festival.",
  },
  {
    question: "Y a-t-il de quoi se restaurer sur place ?",
    reponse:
      "Oui, plusieurs points de restauration sont accessibles pendant toute la durée de l’événement.",
  },
  {
    question: "Les mineurs peuvent-ils venir ?",
    reponse:
      "Oui, sous réserve des modalités précisées par l’organisation et de l’accompagnement éventuel selon l’âge.",
  },
];
---

<Layout title="Infos pratiques - Jumelage">
  <Header />

  <main class="bg-bg pt-24 md:pt-28">
    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <p class="mb-4 text-xs font-bold uppercase tracking-festival text-black/50">
          Festival Jumelage 2026
        </p>

        <div class="grid gap-10 md:grid-cols-[1.1fr_0.9fr] md:items-end md:gap-16">
          <div>
            <h1 class="text-4xl font-black uppercase leading-[0.95] tracking-festival text-[#273b6a] md:text-6xl">
              Infos<br />pratiques
            </h1>

            <p class="mt-8 max-w-xl text-base leading-8 text-black/70">
              Toutes les informations essentielles pour préparer votre venue,
              organiser votre séjour et profiter pleinement de l’expérience
              Jumelage.
            </p>
          </div>

          <div class="bg-blueJ px-6 py-8 text-white md:px-8 md:py-10">
            <p class="text-xs font-bold uppercase tracking-festival text-white/70">
              À retenir
            </p>

            <p class="mt-4 text-2xl font-black uppercase tracking-wide md:text-3xl">
              28 août → 30 août
            </p>

            <p class="mt-5 text-sm leading-7 text-white/90 md:text-base">
              Préparez votre venue à l’avance : accès, hébergement, restauration et
              informations utiles sont réunis ici pour vivre le festival sans faux pas.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <div class="mb-10 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <h2 class="text-3xl font-black uppercase tracking-festival text-[#273b6a] md:text-4xl">
            Tarifs
          </h2>

          <span class="text-xs font-bold uppercase tracking-festival text-black/40">
            Billetterie indicative
          </span>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {tarifs.map((tarif) => (
            <article class="overflow-hidden bg-white shadow-sm transition duration-300 hover:-translate-y-1">
              <div class="h-2 bg-blueJ"></div>

              <div class="px-6 py-8 md:px-8 md:py-10">
                <p class="text-[11px] font-bold uppercase tracking-festival text-black/40">
                  Pass festival
                </p>

                <h3 class="mt-3 text-2xl font-black uppercase tracking-wide text-[#273b6a]">
                  {tarif.titre}
                </h3>

                <p class="mt-5 text-4xl font-black text-blackJ">
                  {tarif.prix}
                </p>

                <p class="mt-6 text-sm leading-7 text-black/70 md:text-base">
                  {tarif.texte}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <div class="mb-10 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <h2 class="text-3xl font-black uppercase tracking-festival text-[#273b6a] md:text-4xl">
            Votre séjour
          </h2>

          <span class="text-xs font-bold uppercase tracking-festival text-black/40">
            Anticipez votre venue
          </span>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {services.map((item) => (
            <article class="overflow-hidden bg-white shadow-sm transition duration-300 hover:-translate-y-1">
              <img
                src={item.image}
                alt={item.titre}
                class="h-52 w-full object-cover"
              />

              <div class="px-6 py-8 md:px-8 md:py-10">
                <h3 class="text-2xl font-black uppercase tracking-wide text-[#273b6a]">
                  {item.titre}
                </h3>

                <p class="mt-5 text-sm leading-7 text-black/70 md:text-base">
                  {item.texte}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-8 md:grid-cols-[0.85fr_1.15fr] md:gap-10">
          <div class="bg-darkJ px-6 py-8 text-white md:px-8 md:py-10">
            <p class="text-xs font-bold uppercase tracking-festival text-white/65">
              Conseils
            </p>

            <h2 class="mt-4 text-3xl font-black uppercase tracking-festival md:text-4xl">
              Avant de venir
            </h2>

            <p class="mt-6 text-sm leading-7 text-white/85 md:text-base">
              Pensez à consulter la programmation, à vérifier votre trajet et à
              anticiper vos besoins sur place pour profiter pleinement du festival.
            </p>

            <div class="mt-8 space-y-4 text-sm font-bold uppercase tracking-festival text-white/90">
              <p>• Arriver en avance</p>
              <p>• Prévoir son hébergement</p>
              <p>• Consulter les accès</p>
            </div>
          </div>

          <div class="bg-white px-6 py-8 shadow-sm md:px-8 md:py-10">
            <p class="text-xs font-bold uppercase tracking-festival text-black/40">
              Questions fréquentes
            </p>

            <div class="mt-8 space-y-8">
              {faq.map((item) => (
                <article class="border-b border-black/10 pb-8 last:border-b-0 last:pb-0">
                  <h3 class="text-lg font-black uppercase tracking-wide text-[#273b6a] md:text-xl">
                    {item.question}
                  </h3>

                  <p class="mt-4 text-sm leading-7 text-black/70 md:text-base">
                    {item.reponse}
                  </p>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-darkJ px-4 py-12 text-white md:px-8 md:py-16">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-end">
          <div>
            <h2 class="text-3xl font-black uppercase tracking-festival md:text-4xl">
              Préparez votre venue
            </h2>

            <p class="mt-5 max-w-2xl text-sm leading-7 text-white/85 md:text-base">
              Consultez aussi le programme, les artistes et les scènes pour
              organiser votre parcours pendant le festival.
            </p>
          </div>

          <div class="grid gap-3 md:grid-cols-3">
            <a
              href="/programme"
              class="bg-blueJ px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-white md:min-w-[180px] md:text-sm"
            >
              Voir le programme
            </a>

            <a
              href="/scenes"
              class="bg-white px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-blackJ md:min-w-[180px] md:text-sm"
            >
              Découvrir les scènes
            </a>

            <a
              href="/artistes"
              class="border border-white px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-white md:min-w-[180px] md:text-sm"
            >
              Voir les artistes
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>