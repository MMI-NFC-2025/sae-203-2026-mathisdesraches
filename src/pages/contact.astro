---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const reseaux = [
  { nom: "Instagram", lien: "#" },
  { nom: "Facebook", lien: "#" },
  { nom: "TikTok", lien: "#" },
  { nom: "YouTube", lien: "#" },
];
---

<Layout title="Contact - Jumelage">
  <Header />

  <main class="bg-bg pt-24 md:pt-28">
    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <p class="mb-4 text-xs font-bold uppercase tracking-festival text-black/50">
          Festival Jumelage 2026
        </p>

        <div class="grid gap-10 md:grid-cols-[1.1fr_0.9fr] md:items-end md:gap-16">
          <div>
            <h1 class="text-4xl font-black uppercase leading-[0.95] tracking-festival text-[#273b6a] md:text-6xl">
              Contact
            </h1>

            <p class="mt-8 max-w-xl text-base leading-8 text-black/70">
              Une question, une demande d’information ou un besoin spécifique ?
              Contactez l’équipe du Festival Jumelage via le formulaire ou nos
              coordonnées directes.
            </p>
          </div>

          <div class="bg-blueJ px-6 py-8 text-white md:px-8 md:py-10">
            <p class="text-xs font-bold uppercase tracking-festival text-white/70">
              Nous écrire
            </p>

            <p class="mt-4 text-2xl font-black uppercase tracking-wide md:text-3xl">
              Restons en lien
            </p>

            <p class="mt-5 text-sm leading-7 text-white/90 md:text-base">
              L’équipe du festival est à votre écoute pour toute question liée à
              l’événement, aux accès, à la programmation ou aux informations
              pratiques.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-8 md:grid-cols-[0.9fr_1.1fr] md:gap-10">
          <div class="bg-darkJ px-6 py-8 text-white md:px-8 md:py-10">
            <p class="text-xs font-bold uppercase tracking-festival text-white/65">
              Coordonnées
            </p>

            <h2 class="mt-4 text-3xl font-black uppercase tracking-festival md:text-4xl">
              Nous contacter
            </h2>

            <div class="mt-8 space-y-6 text-sm leading-7 text-white/85 md:text-base">
              <div>
                <p class="text-xs font-bold uppercase tracking-festival text-white/60">
                  Email
                </p>
                <p class="mt-2">contact@jumelage-festival.fr</p>
              </div>

              <div>
                <p class="text-xs font-bold uppercase tracking-festival text-white/60">
                  Téléphone
                </p>
                <p class="mt-2">03 84 00 00 00</p>
              </div>

              <div>
                <p class="text-xs font-bold uppercase tracking-festival text-white/60">
                  Adresse
                </p>
                <p class="mt-2">
                  Parc Près la Rose<br />
                  25200 Montbéliard<br />
                  France
                </p>
              </div>
            </div>

            <div class="mt-10">
              <p class="text-xs font-bold uppercase tracking-festival text-white/60">
                Réseaux sociaux
              </p>

              <div class="mt-4 flex flex-wrap gap-3">
                {reseaux.map((reseau) => (
                  <a
                    href={reseau.lien}
                    class="border border-white/30 px-4 py-2 text-xs font-bold uppercase tracking-festival text-white transition hover:bg-white hover:text-blackJ"
                  >
                    {reseau.nom}
                  </a>
                ))}
              </div>
            </div>
          </div>

          <div class="bg-white px-6 py-8 shadow-sm md:px-8 md:py-10">
            <p class="text-xs font-bold uppercase tracking-festival text-black/40">
              Formulaire
            </p>

            <h2 class="mt-4 text-3xl font-black uppercase tracking-festival text-[#273b6a] md:text-4xl">
              Envoyez-nous un message
            </h2>

            <form class="mt-8 space-y-6">
              <div class="grid gap-6 md:grid-cols-2">
                <div>
                  <label
                    for="nom"
                    class="mb-2 block text-xs font-bold uppercase tracking-festival text-black/50"
                  >
                    Nom
                  </label>
                  <input
                    id="nom"
                    name="nom"
                    type="text"
                    class="w-full border border-black/10 bg-[#f6f6f6] px-4 py-3 text-sm outline-none transition focus:border-blueJ"
                    placeholder="Votre nom"
                  />
                </div>

                <div>
                  <label
                    for="email"
                    class="mb-2 block text-xs font-bold uppercase tracking-festival text-black/50"
                  >
                    Email
                  </label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    class="w-full border border-black/10 bg-[#f6f6f6] px-4 py-3 text-sm outline-none transition focus:border-blueJ"
                    placeholder="Votre email"
                  />
                </div>
              </div>

              <div>
                <label
                  for="sujet"
                  class="mb-2 block text-xs font-bold uppercase tracking-festival text-black/50"
                >
                  Sujet
                </label>
                <input
                  id="sujet"
                  name="sujet"
                  type="text"
                  class="w-full border border-black/10 bg-[#f6f6f6] px-4 py-3 text-sm outline-none transition focus:border-blueJ"
                  placeholder="Objet de votre message"
                />
              </div>

              <div>
                <label
                  for="message"
                  class="mb-2 block text-xs font-bold uppercase tracking-festival text-black/50"
                >
                  Message
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="7"
                  class="w-full resize-none border border-black/10 bg-[#f6f6f6] px-4 py-3 text-sm outline-none transition focus:border-blueJ"
                  placeholder="Votre message"
                ></textarea>
              </div>

              <button
                type="submit"
                class="bg-blueJ px-6 py-4 text-xs font-bold uppercase tracking-festival text-white transition hover:opacity-90 md:text-sm"
              >
                Envoyer le message
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <div class="overflow-hidden bg-white shadow-sm">
          <div class="grid gap-8 md:grid-cols-[1fr_0.9fr] md:gap-0">
            

            <div class="px-6 py-8 md:px-8 md:py-10">
              <p class="text-xs font-bold uppercase tracking-festival text-black/40">
                Informations
              </p>

              <h2 class="mt-4 text-3xl font-black uppercase tracking-festival text-[#273b6a] md:text-4xl">
                Une équipe disponible
              </h2>

              <p class="mt-6 text-sm leading-7 text-black/70 md:text-base">
                Nous faisons au mieux pour répondre rapidement à toutes les
                demandes liées à la programmation, aux accès, aux informations
                pratiques ou aux besoins spécifiques.
              </p>

              <p class="mt-5 text-sm leading-7 text-black/70 md:text-base">
                N’hésitez pas à nous écrire, nous vous répondrons dès que
                possible.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-darkJ px-4 py-12 text-white md:px-8 md:py-16">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-end">
          <div>
            <h2 class="text-3xl font-black uppercase tracking-festival md:text-4xl">
              Continuez votre visite
            </h2>

            <p class="mt-5 max-w-2xl text-sm leading-7 text-white/85 md:text-base">
              Consultez aussi le programme, les artistes et les infos pratiques
              pour préparer votre expérience du Festival Jumelage.
            </p>
          </div>

          <div class="grid gap-3 md:grid-cols-3">
            <a
              href="/programme"
              class="bg-blueJ px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-white md:min-w-[180px] md:text-sm"
            >
              Voir le programme
            </a>

            <a
              href="/artistes"
              class="bg-white px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-blackJ md:min-w-[180px] md:text-sm"
            >
              Voir les artistes
            </a>

            <a
              href="/infos-pratiques"
              class="border border-white px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-white md:min-w-[180px] md:text-sm"
            >
              Infos pratiques
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>