---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const programme = [
  {
    jour: "Vendredi 28 août",
    dateCourt: "28/08",
    concerts: [
      { heure: "19:00", artiste: "Carley Jener", scene: "Scène 1", image: "/images/carley.png" },
      { heure: "19:30", artiste: "Eden Kaloris", scene: "Scène 2", image: "/images/eden.png" },
      { heure: "20:00", artiste: "Orion Trellian", scene: "Scène 3", image: "/images/orion.png" },
      { heure: "20:30", artiste: "Kira Montrel", scene: "Scène 4", image: "/images/kira.png" },
    ],
  },
  {
    jour: "Samedi 29 août",
    dateCourt: "29/08",
    concerts: [
      { heure: "18:30", artiste: "Maël Drovensky", scene: "Scène 1", image: "/images/mael.png" },
      { heure: "19:00", artiste: "Silas Heraven", scene: "Scène 2", image: "/images/silas.png" },
      { heure: "20:00", artiste: "Tarek Solvim", scene: "Scène 3", image: "/images/tarek.png" },
      { heure: "21:00", artiste: "Jaden Folmar", scene: "Scène 4", image: "/images/jaden.png" },
    ],
  },
  {
    jour: "Dimanche 30 août",
    dateCourt: "30/08",
    concerts: [
      { heure: "18:00", artiste: "Deyan Morliss", scene: "Scène 1", image: "/images/deyan.png" },
      { heure: "18:30", artiste: "Mira Olestand", scene: "Scène 2", image: "/images/mira.png" },
      { heure: "19:30", artiste: "Lioren Savrek", scene: "Scène 3", image: "/images/lioren.png" },
      { heure: "20:30", artiste: "Neriah Volsten", scene: "Scène 4", image: "/images/neriah.png" },
    ],
  },
];
---

<Layout title="Programme - Jumelage">
  <Header />

  <main class="bg-bg pt-24 md:pt-28">
    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <p class="mb-4 text-xs font-bold uppercase tracking-festival text-black/50">
          Festival Jumelage 2026
        </p>

        <div class="grid gap-10 md:grid-cols-[1.1fr_0.9fr] md:items-end md:gap-16">
          <div>
            <h1 class="text-4xl font-black uppercase leading-[0.95] tracking-festival text-[#273b6a] md:text-6xl">
              Le<br />programme
            </h1>

            <p class="mt-8 max-w-xl text-base leading-8 text-black/70">
              Retrouvez les concerts et les scènes de cette édition 2026, jour par jour,
              pour organiser votre parcours et profiter pleinement du festival.
            </p>
          </div>

          <div class="bg-blueJ px-6 py-8 text-white md:px-8 md:py-10">
            <p class="text-xs font-bold uppercase tracking-festival text-white/70">
              À l’affiche
            </p>

            <p class="mt-4 text-2xl font-black uppercase tracking-wide md:text-3xl">
              3 jours de programmation
            </p>

            <p class="mt-5 text-sm leading-7 text-white/90 md:text-base">
              Une programmation répartie sur plusieurs scènes pour faire vibrer
              chaque journée du Festival Jumelage.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl space-y-12">
        {programme.map((bloc) => (
          <section class="overflow-hidden bg-white shadow-sm">
            <div class="bg-blueJ px-4 py-4 text-white md:px-6 md:py-5">
              <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
                <h2 class="text-2xl font-black uppercase tracking-festival md:text-3xl">
                  {bloc.jour}
                </h2>

                <span class="text-xs font-bold uppercase tracking-festival text-white/85 md:text-sm">
                  {bloc.dateCourt}
                </span>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4 px-4 py-5 lg:grid-cols-4 md:px-6 md:py-6">
              {bloc.concerts.map((concert) => (
                <article class="overflow-hidden bg-[#f5f5f5] transition duration-300 hover:-translate-y-1">
                  <img
                    src={concert.image}
                    alt={concert.artiste}
                    class="h-28 w-full object-cover md:h-36"
                  />

                  <div class="px-4 py-4 md:px-5 md:py-5">
                    <span class="mb-3 inline-flex bg-blueJ px-3 py-2 text-[10px] font-bold uppercase tracking-festival text-white md:text-[11px]">
                      {concert.heure}
                    </span>

                    <h3 class="text-sm font-black uppercase tracking-wide text-[#273b6a] md:text-base">
                      {concert.artiste}
                    </h3>

                    <p class="mt-2 text-[10px] font-bold uppercase tracking-festival text-black/60 md:text-xs">
                      {concert.scene}
                    </p>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="bg-darkJ px-4 py-12 text-white md:px-8 md:py-16">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-end">
          <div>
            <h2 class="text-3xl font-black uppercase tracking-festival md:text-4xl">
              Continuez votre exploration
            </h2>

            <p class="mt-5 max-w-2xl text-sm leading-7 text-white/85 md:text-base">
              Consultez aussi les artistes et les scènes pour découvrir chaque univers
              du festival plus en détail.
            </p>
          </div>

          <div class="grid gap-3 md:grid-cols-3">
            <a
              href="/artistes"
              class="bg-blueJ px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-white md:min-w-[180px] md:text-sm"
            >
              Voir les artistes
            </a>

            <a
              href="/scenes"
              class="bg-white px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-blackJ md:min-w-[180px] md:text-sm"
            >
              Découvrir les scènes
            </a>

            <a
              href="/infos-pratiques"
              class="border border-white px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-white md:min-w-[180px] md:text-sm"
            >
              Infos pratiques
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>