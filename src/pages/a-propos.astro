---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const valeurs = [
  {
    titre: "Accessibilité",
    texte:
      "Le Festival Jumelage s’engage à accueillir tous les publics dans un cadre inclusif, ouvert et pensé pour faciliter l’accès à la culture.",
  },
  {
    titre: "Convivialité",
    texte:
      "Le festival repose sur la rencontre, le partage et les échanges. Chaque édition est conçue comme un moment collectif chaleureux et fédérateur.",
  },
  {
    titre: "Esprit local",
    texte:
      "Jumelage valorise les richesses du territoire, les initiatives locales et les liens entre les communautés pour faire vivre une identité forte.",
  },
];

const equipe = [
  {
    nom: "Direction",
    texte:
      "Une équipe de coordination assure la vision générale du festival, sa programmation et le lien entre les différents partenaires.",
    image: "/images/hero_infos_pratiques.png",
  },
  {
    nom: "Technique",
    texte:
      "Les équipes techniques accompagnent la mise en place des scènes, de la lumière, du son et de l’accueil dans les meilleures conditions.",
    image: "/images/hero_apropos.png",
  },
  {
    nom: "Organisation",
    texte:
      "Les bénévoles et l’équipe terrain participent à l’accueil du public, à l’orientation et au bon déroulement des journées du festival.",
    image: "/images/scene3.png",
  },
];
---

<Layout title="À propos - Jumelage">
  <Header />

  <main class="bg-bg pt-24 md:pt-28">
    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <p class="mb-4 text-xs font-bold uppercase tracking-festival text-black/50">
          Festival Jumelage 2026
        </p>

        <div class="grid gap-10 md:grid-cols-[1.1fr_0.9fr] md:items-end md:gap-16">
          <div>
            <h1 class="text-4xl font-black uppercase leading-[0.95] tracking-festival text-[#273b6a] md:text-6xl">
              À<br />propos
            </h1>

            <p class="mt-8 max-w-xl text-base leading-8 text-black/70">
              Découvrez l’histoire, les valeurs et la vision du Festival
              Jumelage, un événement pensé comme un espace de rencontre entre
              les cultures, les publics et les territoires.
            </p>
          </div>

          <div class="bg-blueJ px-6 py-8 text-white md:px-8 md:py-10">
            <p class="text-xs font-bold uppercase tracking-festival text-white/70">
              Notre vision
            </p>

            <p class="mt-4 text-2xl font-black uppercase tracking-wide md:text-3xl">
              Créer du lien par la culture
            </p>

            <p class="mt-5 text-sm leading-7 text-white/90 md:text-base">
              Chaque édition du festival cherche à faire dialoguer les
              générations, les sensibilités artistiques et les territoires à
              travers une programmation vivante et accessible.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-8 md:grid-cols-[0.95fr_1.05fr] md:gap-12">
          

          <div class="bg-white px-6 py-8 shadow-sm md:px-8 md:py-10">
            <p class="text-xs font-bold uppercase tracking-festival text-black/40">
              Historique
            </p>

            <h2 class="mt-4 text-3xl font-black uppercase tracking-festival text-[#273b6a] md:text-4xl">
              Une histoire de rencontres
            </h2>

            <p class="mt-6 text-sm leading-7 text-black/70 md:text-base">
              Depuis sa création, le Festival Jumelage s’inscrit dans une
              dynamique d’ouverture, de partage et de circulation des pratiques
              culturelles. Conçu comme un moment fort de rassemblement, il met
              en lumière des artistes, des initiatives et des énergies venues
              d’horizons variés.
            </p>

            <p class="mt-5 text-sm leading-7 text-black/70 md:text-base">
              Au fil des éditions, le festival a affirmé une identité singulière :
              proposer une expérience conviviale, accessible et profondément
              ancrée dans son territoire, tout en restant attentive à la diversité
              des expressions artistiques.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <div class="mb-10 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <h2 class="text-3xl font-black uppercase tracking-festival text-[#273b6a] md:text-4xl">
            Nos valeurs
          </h2>

          <span class="text-xs font-bold uppercase tracking-festival text-black/40">
            Une identité claire et engagée
          </span>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {valeurs.map((valeur) => (
            <article class="overflow-hidden bg-white shadow-sm">
              <div class="h-2 bg-blueJ"></div>

              <div class="px-6 py-8 md:px-8 md:py-10">
                <h3 class="text-2xl font-black uppercase tracking-wide text-[#273b6a]">
                  {valeur.titre}
                </h3>

                <p class="mt-5 text-sm leading-7 text-black/70 md:text-base">
                  {valeur.texte}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <div class="mb-10 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <h2 class="text-3xl font-black uppercase tracking-festival text-[#273b6a] md:text-4xl">
            L’équipe
          </h2>

          <span class="text-xs font-bold uppercase tracking-festival text-black/40">
            Celles et ceux qui font vivre le festival
          </span>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {equipe.map((item) => (
            <article class="overflow-hidden bg-white shadow-sm transition duration-300 hover:-translate-y-1">
              <img
                src={item.image}
                alt={item.nom}
                class="h-56 w-full object-cover"
              />

              <div class="px-6 py-8 md:px-8 md:py-10">
                <h3 class="text-2xl font-black uppercase tracking-wide text-[#273b6a]">
                  {item.nom}
                </h3>

                <p class="mt-5 text-sm leading-7 text-black/70 md:text-base">
                  {item.texte}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-4 pb-20 md:px-8 md:pb-28">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-8 md:grid-cols-[1fr_1fr] md:gap-10">
          <div class="bg-darkJ px-6 py-8 text-white md:px-8 md:py-10">
            <p class="text-xs font-bold uppercase tracking-festival text-white/65">
              Charte
            </p>

            <h2 class="mt-4 text-3xl font-black uppercase tracking-festival md:text-4xl">
              Une édition engagée
            </h2>

            <p class="mt-6 text-sm leading-7 text-white/85 md:text-base">
              Le Festival Jumelage défend une programmation accessible, un
              accueil attentif aux publics et un ancrage territorial fort. Chaque
              choix s’inscrit dans une volonté de mettre la culture au service du
              lien, du dialogue et de la convivialité.
            </p>
          </div>

        
        </div>
      </div>
    </section>

    <section class="bg-darkJ px-4 py-12 text-white md:px-8 md:py-16">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-end">
          <div>
            <h2 class="text-3xl font-black uppercase tracking-festival md:text-4xl">
              Découvrez le festival autrement
            </h2>

            <p class="mt-5 max-w-2xl text-sm leading-7 text-white/85 md:text-base">
              Consultez aussi le programme, les artistes et les infos pratiques
              pour prolonger votre découverte de l’univers Jumelage.
            </p>
          </div>

          <div class="grid gap-3 md:grid-cols-3">
            <a
              href="/programme"
              class="bg-blueJ px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-white md:min-w-[180px] md:text-sm"
            >
              Voir le programme
            </a>

            <a
              href="/artistes"
              class="bg-white px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-blackJ md:min-w-[180px] md:text-sm"
            >
              Voir les artistes
            </a>

            <a
              href="/infos-pratiques"
              class="border border-white px-5 py-4 text-center text-xs font-bold uppercase tracking-festival text-white md:min-w-[180px] md:text-sm"
            >
              Infos pratiques
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>