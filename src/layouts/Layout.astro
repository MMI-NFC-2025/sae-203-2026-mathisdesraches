---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "JUMELAGE Festival 2026" } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-bg text-blackJ font-sans">
    <slot />
  </body>
</html>